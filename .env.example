# ── Copy this to .env for local development ──
# On Railway, set these directly in the Variables tab

# Auto-provided by Railway PostgreSQL plugin — do not set manually on Railway
DATABASE_URL=postgresql://user:password@host:5432/railway

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=https://your-app.railway.app/auth/google/callback

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-hex

# Sync key — Electron uses this to push data. Keep secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SYNC_API_KEY=replace-with-strong-random-key

# Admin key — for adding teachers via /admin endpoints. Keep very secret.
ADMIN_API_KEY=replace-with-strong-admin-key

# URL of the teacher dashboard (for CORS + OAuth redirect after login)
FRONTEND_URL=https://your-app.railway.app

# Auto-set by Railway
PORT=3000
